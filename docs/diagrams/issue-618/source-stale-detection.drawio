        <mxCell id="ws-build-after" value="let update = SensingUpdate {&#10;  source: s.effective_source(),  // ✅&#10;  tick,&#10;  nodes: ...,&#10;  features: ...,&#10;  ...&#10;}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;fontFamily=Courier New;fontSize=11;align=left;" vertex="1" parent="1">
