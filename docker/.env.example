# ─────────────────────────────────────────────────────────────────────────────
#  RuView sensing-server + MQTT bridge — environment configuration
#  Copy this file to `.env` (in the same directory as docker-compose.yml) and
#  fill in your values. `.env` is read automatically by `docker compose`.
# ─────────────────────────────────────────────────────────────────────────────

# ── sensing-server ───────────────────────────────────────────────────────────

# Data source for the sensing pipeline.
#   auto       — probe UDP:5005 for an ESP32 first; fall back to simulation
#   esp32      — receive real CSI frames from ESP32 over UDP:5005 (recommended
#                once you have at least one node provisioned)
#   wifi       — host Wi-Fi RSSI/scan data (Windows host only)
#   simulated  — synthetic frames, no hardware needed
CSI_SOURCE=auto

# Where the sensing-server scans for `.rvf` model files. The compose file
# already mounts ./models into the container at /app/models — keep this unless
# you mount a different path.
MODELS_DIR=/app/models


# ── mqtt-bridge → Home Assistant ─────────────────────────────────────────────

# Address of your MQTT broker. If Home Assistant is on a different machine,
# use that machine's LAN IP (NOT homeassistant.local — mDNS often fails inside
# containers).
MQTT_HOST=192.168.1.10

# Standard ports: 1883 (plain) / 8883 (TLS). The bridge currently uses plain.
MQTT_PORT=1883

# Credentials for the broker. With Home Assistant's Mosquitto add-on these are
# regular HA user accounts. Create a dedicated `mqtt-bridge` user under
# Settings → People (uncheck Admin, check Local access only) and put its
# username + password here. Leave both empty for an anonymous broker.
MQTT_USER=mqtt-bridge
MQTT_PASS=change-me

# Root MQTT topic. Bridge publishes:
#   <prefix>/availability   (online/offline LWT)
#   <prefix>/state          (flat JSON for HA templates)
#   <prefix>/nodes/<id>     (per-node RSSI / position)
#   <prefix>/event          (one-shot fall events)
MQTT_PREFIX=ruview

# HA Discovery prefix — must match the "Discovery prefix" setting of HA's
# MQTT integration (default `homeassistant`). Change only if you customised
# HA's MQTT discovery prefix.
HA_DISCOVERY_PREFIX=homeassistant

# Friendly name shown in HA's Devices list.
DEVICE_NAME=RuView Sensing

# Unique device id (also used as the prefix of every entity's unique_id).
# Change if you run more than one RuView instance against the same HA.
DEVICE_ID=ruview

# Bridge log verbosity: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
